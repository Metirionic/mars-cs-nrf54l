/ {
    chosen {
        cobs-uart = &uart20;
        zephyr,shell-uart = &uart30;
        zephyr,console = &uart30;
        zephyr,uart-mcumgr = &uart30;
        zephyr,bt-mon-uart = &uart30;
        zephyr,bt-c2h-uart = &uart30;

    };
};

/*
 * The nrf54l15tag base DTS ships no uart20/uart30 pinctrl (the tag board's
 * console path is RTT/NUS, not a fixed UART), so the pins the application
 * routes these uarts to must come from the overlay. The assignment below is a
 * build-enabling default picked from the tag board's exposed, conflict-free
 * pins (see boards/nordic/nrf54l15tag/doc/index.rst). uart20 mirrors the
 * Fanstel BM15C overlay (P1.13/P1.14); verify against your tag wiring before
 * flashing.
 *   uart20 (COBS ranging): TX P1.13 / RX P1.14
 *   uart30 (shell/console): TX P0.01 / RX P0.02
 */
&pinctrl {
    /omit-if-no-ref/ uart20_default: uart20_default {
        group1 {
            psels = <NRF_PSEL(UART_TX, 1, 13)>;
        };
        group2 {
            psels = <NRF_PSEL(UART_RX, 1, 14)>;
            bias-pull-up;
        };
    };

    /omit-if-no-ref/ uart20_sleep: uart20_sleep {
        group1 {
            psels = <NRF_PSEL(UART_TX, 1, 13)>,
                    <NRF_PSEL(UART_RX, 1, 14)>;
            low-power-enable;
        };
    };

    /omit-if-no-ref/ uart30_default: uart30_default {
        group1 {
            psels = <NRF_PSEL(UART_TX, 0, 1)>;
        };
        group2 {
            psels = <NRF_PSEL(UART_RX, 0, 2)>;
            bias-pull-up;
        };
    };

    /omit-if-no-ref/ uart30_sleep: uart30_sleep {
        group1 {
            psels = <NRF_PSEL(UART_TX, 0, 1)>,
                    <NRF_PSEL(UART_RX, 0, 2)>;
            low-power-enable;
        };
    };
};

&uart30 {
    status = "okay";
    current-speed = <921600>;
    pinctrl-0 = <&uart30_default>;
    pinctrl-1 = <&uart30_sleep>;
    pinctrl-names = "default", "sleep";
};

&uart20 {
    status = "okay";
    current-speed = <921600>;
    pinctrl-0 = <&uart20_default>;
    pinctrl-1 = <&uart20_sleep>;
    pinctrl-names = "default", "sleep";
};

/ {
	cs_antenna_switch: cs-antenna-config {
		status = "okay";
		compatible = "nordic,bt-cs-antenna-switch";
		ant-gpios = <&gpio1 9 GPIO_ACTIVE_HIGH>,
			    <&gpio1 10 GPIO_ACTIVE_HIGH>;
		multiplexing-mode = <0>;
	};
};

/* delete other nodes that drive the antenna pins so there is no duplicate access */
/delete-node/ &sky13348;

&gpio1 {
	/delete-node/ antenna_switch_v1;
	/delete-node/ antenna_switch_v2;
};
