/*
 * Shared uart20 COBS-UART pinctrl + enable for boards that route the COBS
 * ranging stream to P1.13 (TX) / P1.14 (RX) at 921600 baud. Included by the
 * board overlays that use this pinout (currently nrf54l15tag and
 * fanstel_bm15c). Both expose the COBS stream on these pins via an external
 * UART-to-USB adapter (e.g. FT232R) — neither has an onboard USB/UART bridge
 * wired to these pins.
 *
 * SPDX-License-Identifier: MIT
 */

&pinctrl {
	/omit-if-no-ref/ uart20_default: uart20_default {
		group1 {
			psels = <NRF_PSEL(UART_TX, 1, 13)>;
		};
		group2 {
			psels = <NRF_PSEL(UART_RX, 1, 14)>;
			bias-pull-up;
		};
	};

	/omit-if-no-ref/ uart20_sleep: uart20_sleep {
		group1 {
			psels = <NRF_PSEL(UART_TX, 1, 13)>,
				<NRF_PSEL(UART_RX, 1, 14)>;
			low-power-enable;
		};
	};
};

&uart20 {
	status = "okay";
	current-speed = <921600>;
	pinctrl-0 = <&uart20_default>;
	pinctrl-1 = <&uart20_sleep>;
	pinctrl-names = "default", "sleep";
};
