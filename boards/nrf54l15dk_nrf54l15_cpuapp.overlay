/* SPDX-License-Identifier: MIT */

/ {
    chosen {
        cobs-uart = &uart20;
        zephyr,shell-uart = &uart30;
        zephyr,console = &uart30;
        zephyr,uart-mcumgr = &uart30;
        zephyr,bt-mon-uart = &uart30;
        zephyr,bt-c2h-uart = &uart30;

    };
};

&uart30 {
    status = "okay";
    current-speed = <921600>;
};

&uart20 {
    status = "okay";
    current-speed = <921600>;
};

/* Antenna control below is implemented as described in the CS documentation.
 * See cs_antenna_switch.c
 */
/ {
    cs_antenna_switch: cs-antenna-config {
        status = "okay";
        compatible = "nordic,bt-cs-antenna-switch";
        ant-gpios = <&gpio1 9 (GPIO_ACTIVE_HIGH)>,
                    <&gpio1 10 (GPIO_ACTIVE_HIGH)>;
        multiplexing-mode = <1>;
    };
};
